# osu-api-proxy — host nginx server block.
#
# 1. Add this once to the http {} scope (e.g. /etc/nginx/nginx.conf):
#
#       limit_req_zone $binary_remote_addr zone=osuapi:10m rate=3r/s;
#
# 2. Drop this server block into /etc/nginx/sites-available/osu-proxy.conf
#    and symlink it from sites-enabled, then `nginx -t && systemctl reload nginx`.
# 3. ssl_certificate / ssl_certificate_key are managed by your existing
#    cert tooling (certbot, acme.sh, etc.).

server {
    listen 443 ssl http2;
    server_name osu-proxy.local;

    # ssl_certificate     /etc/letsencrypt/live/osu-proxy/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/osu-proxy/privkey.pem;

    access_log /var/log/nginx/osu-proxy.access.log;
    error_log  /var/log/nginx/osu-proxy.error.log;

    location / {
        limit_req zone=osuapi burst=10 nodelay;

        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_request_buffering off;
        proxy_buffering off;

        proxy_connect_timeout 10s;
        proxy_read_timeout    90s;
        proxy_send_timeout    90s;
    }
}

server {
    listen 80;
    server_name osu-proxy.local;
    return 301 https://$host$request_uri;
}

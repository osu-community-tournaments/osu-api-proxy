#
# Every request must present the secret in one of:
#   - Header:    X-Proxy-Secret: YOUR-SECRET-HERE
#   - Query arg: ?proxy_secret=YOUR-SECRET-HERE   (stripped before forwarding)
#
# Step 1. Add these to the http {} scope (e.g. /etc/nginx/nginx.conf) once,
#         and replace YOUR-SECRET-HERE with the actual secret. The secret
#         lives in the nginx config — keep that file mode 0640 root:nginx.
#
#       limit_req_zone $binary_remote_addr zone=osuapi:10m rate=3r/s;
#
#       resolver 1.1.1.1 8.8.8.8 valid=300s ipv6=off;
#       resolver_timeout 5s;
#
# Step 2. Copy this file to /etc/nginx/sites-available/osu-proxy.conf,
#         adjust `server_name` and `ssl_certificate*` paths, symlink it
#         from sites-enabled/, then run `nginx -t && systemctl reload nginx`.

map $http_x_proxy_secret $osu_hdr_ok { default 0; "YOUR-SECRET-HERE" 1; }
map $arg_proxy_secret    $osu_arg_ok { default 0; "YOUR-SECRET-HERE" 1; }

server {
    listen 443 ssl http2;
    server_name osu-proxy.local;

    # ssl_certificate     /etc/letsencrypt/live/osu-proxy/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/osu-proxy/privkey.pem;

    access_log /var/log/nginx/osu-proxy.access.log;
    error_log  /var/log/nginx/osu-proxy.error.log;

    set $upstream "osu.ppy.sh";

    location = / {
        default_type application/json;
        return 200 '{"status":"ok","proxy":"osu-api-proxy"}';
    }

    location ~ ^/(api/|oauth/token) {
        limit_req zone=osuapi burst=10 nodelay;

        # Reject if neither header nor query carried a valid secret.
        set $osu_authed "${osu_hdr_ok}${osu_arg_ok}";
        if ($osu_authed = "00") {
            default_type application/json;
            return 401 '{"error":"Invalid or missing X-Proxy-Secret."}';
        }

        # Strip ?proxy_secret=... from the query string before forwarding.
        # Two passes cover "first arg" and "middle/last arg" positions.
        if ($args ~* "^(.*)&proxy_secret=[^&]*(.*)$") { set $args $1$2; }
        if ($args ~* "^proxy_secret=[^&]*&?(.*)$")    { set $args $1; }

        # Rebuild query string so an empty $args doesn't produce a trailing `?`.
        set $clean_qs "";
        if ($args) { set $clean_qs "?$args"; }

        proxy_pass https://$upstream$uri$clean_qs;
        proxy_http_version 1.1;
        proxy_ssl_server_name on;
        proxy_ssl_name $upstream;
        proxy_set_header Host $upstream;

        # Don't leak the secret (header form) upstream.
        proxy_set_header X-Proxy-Secret "";
        proxy_set_header CF-Connecting-IP "";
        proxy_set_header CF-Ray "";
        proxy_set_header CF-Visitor "";
        proxy_set_header CF-IPCountry "";
        proxy_set_header CF-Worker "";

        proxy_request_buffering off;
        proxy_buffering off;

        proxy_connect_timeout 10s;
        proxy_read_timeout    90s;
        proxy_send_timeout    90s;
    }

    location / {
        default_type application/json;
        return 404 '{"error":"This proxy only forwards /api/* and /oauth/token."}';
    }
}

server {
    listen 80;
    server_name osu-proxy.local;
    return 301 https://$host$request_uri;
}

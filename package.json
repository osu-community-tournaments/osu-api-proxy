{
  "name": "osu-api-proxy",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted Fastify proxy for the osu! API v1/v2",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "node --test --import tsx src/*.test.ts",
    "typecheck": "tsc --noEmit",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
